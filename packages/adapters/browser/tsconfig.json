{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "composite": true,
    "skipLibCheck": true,
    "target": "es2022",
    "module": "esnext"
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "../../engine" }
  ]
}
